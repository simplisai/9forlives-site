# Redirecionamentos para Netlify
# Este arquivo garante que a página principal seja servida corretamente

# Redireciona a raiz para o arquivo HTML principal (v2), forçando prioridade
/    /pages/9forlives_page_v2.html    200!

# Redireciona index.html para o arquivo principal (v2)
/index.html    /pages/9forlives_page_v2.html    301!

# Garante que a página antiga sempre vá para a V2
/pages/9forlives-page.html    /pages/9forlives_page_v2.html    301!

# Mantém a versão antiga acessível via URL direta
/v1    /pages/9forlives-page.html    200

# Rotas de onboarding (rewrite mantendo a URL)
/onboarding-mis-pt    /pages/onboarding-missionary.html    200
/onboarding-fin-pt    /pages/onboarding-financier.html     200

# Nova página Manifesto
/manifesto-pt    /pages/manifesto-pt.html    200
/manifest-en    /pages/manifest-en.html    200

# Página de Patentes e Insígnias
/ranks           /pages/ranks.html           200

# Garante entrega direta dos assets estáticos
/images/*        /images/:splat              200
/js/*            /js/:splat                  200

# Importante: não usar fallback global com 200! para não interceptar assets
# (ex.: /images/*). Isso quebrava logo e imagens no deploy.
