const OnboardingService = {
  
  /**
   * Cria um missionário
   * @param {Object} formData - Dados do formulário
   * @returns {Promise<Object>} - Resultado da criação
   */
  async createMissionary(formData) {
    try {
      console.log('[MISSIONARY] Iniciando cadastro:', formData.email)
      
      const payload = {
        role: 'MISSIONARY',
        email: formData.email,
        password: formData.password,
        name: formData.name,
        whatsapp: this.formatPhone(formData.whatsapp),
        cpf: this.formatCPF(formData.cpf),
        birthDate: formData.birthDate,
        region: formData.region,
        address: {
          street: formData.street,
          number: formData.number,
          complement: formData.complement || '',
          neighborhood: formData.neighborhood,
          city: formData.city,
          state: formData.state,
          zipCode: this.formatCEP(formData.zipCode)
        },
        church: formData.church,
        pastor: formData.pastor,
        pastorPhone: this.formatPhone(formData.pastorPhone),
        membershipYears: parseInt(formData.membershipYears) || 0,
        specialization: formData.specialization || '',
        project: formData.project || ''
      }

      console.log('[MISSIONARY] Payload preparado:', payload)

      const { data, error } = await window.supabaseClient.functions.invoke(
        window.SUPABASE_CONFIG.functions.createUserOnboarding,
        { body: payload }
      )

      if (error) {
        console.error('[MISSIONARY] Erro da Edge Function:', error)
        throw error
      }

      if (data.error) {
        console.error('[MISSIONARY] Erro retornado pela função:', data.error)
        throw new Error(data.error)
      }

      console.log('[MISSIONARY] ✅ Cadastro concluído!', data)
      return { success: true, data }

    } catch (error) {
      console.error('[MISSIONARY] ❌ Erro:', error)
      return { 
        success: false, 
        error: error.message || 'Erro ao criar conta de missionário' 
      }
    }
  },

  /**
   * Cria um financiador
   * @param {Object} formData - Dados do formulário
   * @returns {Promise<Object>} - Resultado da criação
   */
  async createFinancier(formData) {
    try {
      console.log('[FINANCIER] Iniciando cadastro:', formData.email)
      
      const payload = {
        role: 'FINANCIER',
        email: formData.email,
        password: formData.password,
        name: formData.name,
        phone: formData.phone ? this.formatPhone(formData.phone) : null
      }

      console.log('[FINANCIER] Payload preparado:', payload)

      const { data, error } = await window.supabaseClient.functions.invoke(
        window.SUPABASE_CONFIG.functions.createUserOnboarding,
        { body: payload }
      )

      if (error) {
        console.error('[FINANCIER] Erro da Edge Function:', error)
        throw error
      }

      if (data.error) {
        console.error('[FINANCIER] Erro retornado pela função:', data.error)
        throw new Error(data.error)
      }

      console.log('[FINANCIER] ✅ Cadastro concluído!', data)
      
      // Salvar userId para usar no checkout
      localStorage.setItem('9forlives_financier_user_id', data.userId)
      localStorage.setItem('9forlives_financier_email', formData.email)
      
      return { success: true, data }

    } catch (error) {
      console.error('[FINANCIER] ❌ Erro:', error)
      return { 
        success: false, 
        error: error.message || 'Erro ao criar conta de financiador' 
      }
    }
  },

  /**
   * Upload de documentos do missionário
   * @param {string} userId - ID do usuário
   * @param {Object} files - Objeto com os arquivos
   * @returns {Promise<Object>} - URLs dos documentos
   */
  async uploadDocuments(userId, files) {
    try {
      console.log('[UPLOAD] Iniciando upload de documentos para usuário:', userId)
      
      const uploads = []
      const bucket = 'missionary-documents'

      for (const [fieldName, file] of Object.entries(files)) {
        if (!file) continue

        const fileExt = file.name.split('.').pop()
        const fileName = `${userId}/${fieldName}-${Date.now()}.${fileExt}`
        
        console.log(`[UPLOAD] Enviando ${fieldName}:`, fileName)

        const { data, error } = await window.supabaseClient.storage
          .from(bucket)
          .upload(fileName, file, {
            cacheControl: '3600',
            upsert: false
          })

        if (error) {
          console.error(`[UPLOAD] Erro ao enviar ${fieldName}:`, error)
          throw error
        }

        // Obter URL pública
        const { data: publicData } = window.supabaseClient.storage
          .from(bucket)
          .getPublicUrl(data.path)

        uploads.push({ 
          fieldName, 
          fileName: data.path, 
          url: publicData.publicUrl 
        })

        console.log(`[UPLOAD] ✅ ${fieldName} enviado com sucesso`)
      }

      // Atualizar profile com status de documentos
      await this.updateDocumentStatus(userId, uploads)

      console.log('[UPLOAD] ✅ Todos os documentos enviados:', uploads)
      return { success: true, uploads }

    } catch (error) {
      console.error('[UPLOAD] ❌ Erro:', error)
      return { success: false, error: error.message }
    }
  },

  /**
   * Atualiza status de documentos no perfil do missionário
   */
  async updateDocumentStatus(userId, uploads) {
    try {
      const documentStatus = {
        uploaded: true,
        uploadedAt: new Date().toISOString(),
        files: uploads.map(u => ({
          type: u.fieldName,
          url: u.url
        }))
      }

      const { error } = await window.supabaseClient
        .from('missionaries')
        .update({ 
          documents_submitted: documentStatus 
        })
        .eq('user_id', userId)

      if (error) throw error

      console.log('[UPLOAD] ✅ Status de documentos atualizado no banco')
    } catch (error) {
      console.error('[UPLOAD] ⚠️ Erro ao atualizar status:', error)
    }
  },

  /**
   * Helpers para formatação
   */
  formatPhone(phone) {
    if (!phone) return ''
    // Remove tudo exceto números
    return phone.replace(/\D/g, '')
  },

  formatCPF(cpf) {
    if (!cpf) return ''
    // Remove tudo exceto números
    return cpf.replace(/\D/g, '')
  },

  formatCEP(cep) {
    if (!cep) return ''
    // Remove tudo exceto números
    return cep.replace(/\D/g, '')
  }
}

// Export global
window.OnboardingService = OnboardingService

console.log('✅ Onboarding Service loaded')
```

