### ARQUIVO 5: `supabase/functions/create-user-onboarding/index.ts`

```typescript
import { serve } from 'https://deno.land/std@0.168.0/http/server.ts'
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'
import { z } from 'https://deno.land/x/zod@v3.22.4/mod.ts'

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
}

// ============================================
// SCHEMAS DE VALIDAÇÃO
// ============================================

const missionarySchema = z.object({
  email: z.string().email('Email inválido'),
  password: z.string().min(6, 'Senha deve ter no mínimo 6 caracteres'),
  role: z.literal('MISSIONARY'),
  name: z.string().min(3, 'Nome deve ter no mínimo 3 caracteres'),
  whatsapp: z.string().min(10, 'WhatsApp inválido'),
  cpf: z.string().regex(/^\d{11}$/, 'CPF deve conter 11 dígitos'),
  birthDate: z.string(), // ISO date
  region: z.string().min(2, 'Região obrigatória'),
  address: z.object({
    street: z.string(),
    number: z.string(),
    complement: z.string().optional(),
    neighborhood: z.string(),
    city: z.string(),
    state: z.string(),
    zipCode: z.string()
  }),
  church: z.string().min(3, 'Nome da igreja obrigatório'),
  pastor: z.string().min(3, 'Nome do pastor obrigatório'),
  pastorPhone: z.string().min(10, 'Telefone do pastor inválido'),
  membershipYears: z.number().min(0).max(100),
  specialization: z.string().optional(),
  project: z.string().optional()
})

const financierSchema = z.object({
  email: z.string().email('Email inválido'),
  password: z.string().min(6, 'Senha deve ter no mínimo 6 caracteres'),
  role: z.literal('FINANCIER'),
  name: z.string().min(3, 'Nome deve ter no mínimo 3 caracteres'),
  phone: z.string().optional()
})

// ============================================
// CONSTANTS
// ============================================

const DEFAULT_ORG_ID = '00000000-0000-0000-0000-000000000001'
const DEFAULT_CLUSTER_ID = 'a6d47598-4420-44c6-9f52-09cb52ffe669'

// ============================================
// MAIN HANDLER
// ============================================

serve(async (req) => {
  // Handle CORS preflight
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    // Initialize Supabase Admin Client
    const supabaseUrl = Deno.env.get('SUPABASE_URL')!
    const supabaseKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
    
    if (!supabaseUrl || !supabaseKey) {
      throw new Error('Supabase environment variables not configured')
    }

    const supabase = createClient(supabaseUrl, supabaseKey)

    // Parse request body
    const body = await req.json()
    const role = body.role

    console.log(`[CREATE_USER] Received request for role: ${role}`)

    // Validate schema based on role
    const schema = role === 'MISSIONARY' ? missionarySchema : financierSchema
    const validation = schema.safeParse(body)

    if (!validation.success) {
      console.error('[VALIDATION] Failed:', validation.error.flatten())
      return new Response(
        JSON.stringify({ 
          error: 'Dados inválidos',
          details: validation.error.flatten().fieldErrors
        }),
        { 
          headers: { ...corsHeaders, 'Content-Type': 'application/json' }, 
          status: 400 
        }
      )
    }

    const input = validation.data
    let userId: string | null = null

    try {
      // STEP 1: Create auth user
      console.log(`[CREATE_USER] Creating auth user for ${input.email}`)
      
      const { data: authData, error: authError } = await supabase.auth.admin.createUser({
        email: input.email,
        password: input.password,
        email_confirm: true,
        user_metadata: {
          name: input.name,
          role: input.role,
          created_at: new Date().toISOString()
        }
      })

      if (authError || !authData.user) {
        console.error('[CREATE_USER] Auth error:', authError)
        throw new Error(authError?.message || 'Failed to create auth user')
      }

      userId = authData.user.id
      console.log(`[CREATE_USER] ✅ Auth user created: ${userId}`)

      // STEP 2: Create profile
      console.log(`[CREATE_PROFILE] Creating profile for ${userId}`)
      
      const profileData: any = {
        id: userId,
        email: input.email,
        name: input.name,
        role: input.role,
        status: 'PENDING_APPROVAL',
        active: true,
        organization_id: DEFAULT_ORG_ID,
        cluster_id: DEFAULT_CLUSTER_ID,
        preferred_language: 'pt-BR',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      }

      if (role === 'MISSIONARY') {
        const missionary = input as z.infer<typeof missionarySchema>
        profileData.whatsapp_number = missionary.whatsapp
        profileData.phone_number = missionary.whatsapp
        profileData.document = parseInt(missionary.cpf)
        profileData.birth_date = missionary.birthDate
      }

      const { error: profileError } = await supabase
        .from('profiles')
        .insert(profileData)

      if (profileError) {
        console.error('[CREATE_PROFILE] Error:', profileError)
        throw profileError
      }

      console.log(`[CREATE_PROFILE] ✅ Profile created successfully`)

      // STEP 3: Create role-specific record
      if (role === 'MISSIONARY') {
        console.log(`[CREATE_MISSIONARY] Creating missionary record`)
        
        const missionary = input as z.infer<typeof missionarySchema>
        const fullAddress = `${missionary.address.street}, ${missionary.address.number}${missionary.address.complement ? ' - ' + missionary.address.complement : ''} - ${missionary.address.neighborhood}, ${missionary.address.city}/${missionary.address.state} - CEP: ${missionary.address.zipCode}`

        const { error: missionaryError } = await supabase
          .from('missionaries')
          .insert({
            user_id: userId,
            organization_id: DEFAULT_ORG_ID,
            region: missionary.region,
            location: fullAddress,
            church_name: missionary.church,
            pastor_name: missionary.pastor,
            pastor_phone: missionary.pastorPhone,
            membership_years: missionary.membershipYears,
            specialization: missionary.specialization || null,
            missionary_project_name: missionary.project || null,
            documents_submitted: { status: 'PENDING_UPLOAD', uploaded_at: null },
            active: true,
            created_at: new Date().toISOString(),
            updated_at: new Date().toISOString()
          })

        if (missionaryError) {
          console.error('[CREATE_MISSIONARY] Error:', missionaryError)
          throw missionaryError
        }

        console.log(`[CREATE_MISSIONARY] ✅ Missionary record created`)
      } else {
        console.log(`[CREATE_FINANCIER] Creating financier record`)
        
        const { error: financierError } = await supabase
          .from('financiers')
          .insert({
            user_id: userId,
            subscription_plan: 0,
            current_balance_cents: 0,
            spt_balance: 0,
            spt_allocated: 0,
            organization_id: DEFAULT_ORG_ID,
            created_at: new Date().toISOString(),
            updated_at: new Date().toISOString()
          })

        if (financierError) {
          console.error('[CREATE_FINANCIER] Error:', financierError)
          throw financierError
        }

        console.log(`[CREATE_FINANCIER] ✅ Financier record created`)
      }

      // SUCCESS RESPONSE
      console.log(`[CREATE_USER] ✅ User creation completed for ${input.email}`)
      
      return new Response(
        JSON.stringify({ 
          success: true, 
          userId: userId,
          role: role,
          email: input.email,
          message: 'Usuário criado com sucesso!'
        }),
        { 
          headers: { ...corsHeaders, 'Content-Type': 'application/json' }, 
          status: 201 
        }
      )

    } catch (dbError: any) {
      // ROLLBACK: Delete auth user if database operations failed
      if (userId) {
        console.error(`[ROLLBACK] Database error occurred, deleting auth user ${userId}`)
        try {
          await supabase.auth.admin.deleteUser(userId)
          console.log(`[ROLLBACK] ✅ Auth user ${userId} deleted successfully`)
        } catch (deleteError) {
          console.error(`[ROLLBACK] ❌ Failed to delete user ${userId}:`, deleteError)
        }
      }
      
      throw dbError
    }

  } catch (error: any) {
    console.error('[ERROR]', error)
    
    return new Response(
      JSON.stringify({ 
        error: error.message || 'Erro interno do servidor',
        details: error.details || error.hint || null
      }),
      { 
        headers: { ...corsHeaders, 'Content-Type': 'application/json' }, 
        status: 500 
      }
    )
  }
})
