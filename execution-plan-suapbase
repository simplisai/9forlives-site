async function handleMissionarySubmit(event) {
  event.preventDefault()
  
  const form = event.target
  const submitButton = form.querySelector('button[type="submit"]')
  
  try {
    // Mostrar loading
    UIHelpers.showLoading(submitButton, '⏳ Criando sua conta...')
    
    // Coletar dados do formulário
    const formData = {
      // Dados pessoais
      name: form.querySelector('[name="name"]')?.value,
      email: form.querySelector('[name="email"]')?.value,
      cpf: form.querySelector('[name="cpf"]')?.value,
      whatsapp: form.querySelector('[name="whatsapp"]')?.value,
      birthDate: form.querySelector('[name="birthDate"]')?.value,
      password: form.querySelector('[name="password"]')?.value,
      
      // Endereço
      zipCode: form.querySelector('[name="zipCode"]')?.value,
      street: form.querySelector('[name="street"]')?.value,
      number: form.querySelector('[name="number"]')?.value,
      complement: form.querySelector('[name="complement"]')?.value || '',
      neighborhood: form.querySelector('[name="neighborhood"]')?.value,
      city: form.querySelector('[name="city"]')?.value,
      state: form.querySelector('[name="state"]')?.value,
      
      // Igreja
      church: form.querySelector('[name="church"]')?.value,
      pastor: form.querySelector('[name="pastor"]')?.value,
      pastorPhone: form.querySelector('[name="pastorPhone"]')?.value,
      membershipYears: form.querySelector('[name="membershipYears"]')?.value || '0',
      
      // Missão
      region: form.querySelector('[name="region"]')?.value,
      specialization: form.querySelector('[name="specialization"]')?.value || '',
      project: form.querySelector('[name="project"]')?.value || ''
    }

    // Validar campos obrigatórios
    const requiredFields = ['name', 'email', 'cpf', 'whatsapp', 'birthDate', 'password', 
                            'zipCode', 'street', 'number', 'neighborhood', 'city', 'state',
                            'church', 'pastor', 'pastorPhone', 'region']
    
    const missingFields = requiredFields.filter(field => !formData[field])
    
    if (missingFields.length > 0) {
      throw new Error(`Por favor, preencha todos os campos obrigatórios: ${missingFields.join(', ')}`)
    }

    console.log('[FORM] Dados coletados:', formData)
    
    // Enviar para o serviço
    const result = await window.OnboardingService.createMissionary(formData)
    
    if (!result.success) {
      throw new Error(result.error)
    }

    // Sucesso! Coletar e fazer upload de documentos (se houver)
    const documents = collectDocuments(form)
    
    if (documents && Object.keys(documents).length > 0) {
      console.log('[FORM] Fazendo upload de documentos...')
      UIHelpers.showLoading(submitButton, '📤 Enviando documentos...')
      
      const uploadResult = await window.OnboardingService.uploadDocuments(
        result.data.userId, 
        documents
      )
      
      if (!uploadResult.success) {
        console.warn('[FORM] Erro ao enviar documentos, mas conta foi criada:', uploadResult.error)
      }
    }

    // Mostrar mensagem de sucesso
    UIHelpers.showSuccessModal(
      '🎉 Cadastro Realizado com Sucesso!',
      'Sua conta foi criada. Em breve você receberá um e-mail de confirmação.',
      'window.location.href = "/9forlives-page.html"'
    )

  } catch (error) {
    console.error('[FORM] Erro no cadastro:', error)
    UIHelpers.showToast(error.message || 'Erro ao criar conta', 'error')
    UIHelpers.hideLoading(submitButton)
  }
}

